<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Albo Downloader"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="2dp" />

        <!-- Connection status -->
        <TextView
            android:id="@+id/connectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connecting to PC..."
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Settings panel -->
        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PC SERVER URL"
                android:textColor="#555555"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/serverInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="#222222"
                android:padding="10dp"
                android:inputType="textUri" />
        </LinearLayout>

        <!-- URL input row with X and Paste -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Paste URL here..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:padding="14dp"
                android:inputType="textUri"
                android:imeOptions="actionDone"
                android:maxLines="2" />

            <Button
                android:id="@+id/clearBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                android:text="✕"
                android:textColor="#666666"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/pasteBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Paste"
                android:textColor="#FE2C55"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <!-- Folder picker row -->
        <LinearLayout
            android:id="@+id/folderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/folderText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📁 Save to: Default"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change ›"
                android:textColor="#FE2C55"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Info card -->
        <LinearLayout
            android:id="@+id/infoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/uploaderText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste a URL to get started"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginBottom="12dp"
            android:progressTint="#FE2C55"
            android:progressBackgroundTint="#2A2A2A"
            android:max="100"
            android:visibility="gone" />

        <!-- Format buttons -->
        <LinearLayout
            android:id="@+id/menuPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button android:id="@+id/btnVideo"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="8dp" android:text="🎬  Video"
                android:textColor="#FFFFFF" android:textSize="15sp" android:background="#1E1E1E" />

            <Button android:id="@+id/btnAudio"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="8dp" android:text="🎵  Audio (MP3)"
                android:textColor="#FFFFFF" android:textSize="15sp" android:background="#1E1E1E" />

            <!-- YouTube/Vimeo/Twitch only -->
            <Button android:id="@+id/btnSubtitles"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="8dp" android:text="📝  Subtitles (SRT with timestamps)"
                android:textColor="#FFFFFF" android:textSize="14sp" android:background="#1E1E1E"
                android:visibility="gone" />

            <!-- YouTube only -->
            <Button android:id="@+id/btnTextOnly"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="8dp" android:text="📄  Text Only (no timestamps)"
                android:textColor="#FFFFFF" android:textSize="14sp" android:background="#1E1E1E"
                android:visibility="gone" />

            <!-- Instagram/TikTok/Pinterest only -->
            <Button android:id="@+id/btnPhotos"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="8dp" android:text="🖼  Photos / Album"
                android:textColor="#FFFFFF" android:textSize="15sp" android:background="#1E1E1E"
                android:visibility="gone" />

            <!-- YouTube playlist only -->
            <Button android:id="@+id/btnPlaylist"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="8dp" android:text="📋  Download Playlist (up to 150)"
                android:textColor="#FFFFFF" android:textSize="14sp" android:background="#1E1E1E"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Again panel -->
        <LinearLayout
            android:id="@+id/againPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <Button android:id="@+id/btnAgain"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginTop="6dp" android:text="🔄  Download another format"
                android:textColor="#888888" android:textSize="14sp" android:background="#1A1A1A" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TikTok  •  YouTube  •  Instagram  •  Twitter/X  •  Facebook  •  Reddit  •  Vimeo  •  Twitch  •  and more"
            android:textColor="#2A2A2A"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Albo Downloader"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="2dp" />

        <!-- Connection status — tap to open settings -->
        <TextView
            android:id="@+id/connectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connecting to PC..."
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Settings panel -->
        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PC SERVER URL"
                android:textColor="#555555"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/serverInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="#222222"
                android:padding="10dp"
                android:inputType="textUri" />

        </LinearLayout>

        <!-- URL input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Paste URL here..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:padding="14dp"
                android:inputType="textUri"
                android:imeOptions="actionDone"
                android:maxLines="2" />

            <Button
                android:id="@+id/pasteBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Paste"
                android:textColor="#FE2C55"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <!-- Info card -->
        <LinearLayout
            android:id="@+id/infoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/uploaderText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste a URL to get started"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginBottom="12dp"
            android:progressTint="#FE2C55"
            android:progressBackgroundTint="#2A2A2A"
            android:max="100"
            android:visibility="gone" />

        <!-- Main menu - matches Telegram bot buttons -->
        <LinearLayout
            android:id="@+id/menuPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Video — tap expands quality sub-menu -->
            <Button
                android:id="@+id/btnVideo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="🎬  Video"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E" />

            <!-- Quality sub-menu (hidden until Video tapped) -->
            <LinearLayout
                android:id="@+id/qualityPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnBest"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Best"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="#FE2C55" />

                <Button
                    android:id="@+id/btn720p"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="720p"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="#2A2A2A" />

                <Button
                    android:id="@+id/btn480p"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="480p"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="#2A2A2A" />

            </LinearLayout>

            <!-- Audio -->
            <Button
                android:id="@+id/btnAudio"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="🎵  Audio (MP3)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E" />

            <!-- Subtitles (video + SRT file) -->
            <Button
                android:id="@+id/btnSubtitles"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="📝  Subtitles"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E" />

            <!-- Text Only (SRT only, no video) -->
            <Button
                android:id="@+id/btnTextOnly"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="📄  Text Only"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E" />

            <!-- Playlist — only shown for YouTube playlist URLs -->
            <Button
                android:id="@+id/btnPlaylist"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="📋  Download Playlist (up to 150)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Download another format button (shown after download) -->
        <LinearLayout
            android:id="@+id/againPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnAgain"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="🔄  Download another format"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:background="#1A1A1A" />

        </LinearLayout>

        <!-- Supported sites footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TikTok  •  YouTube  •  Instagram  •  Twitter/X  •  Facebook  •  Reddit  •  Vimeo  •  Twitch  •  and more"
            android:textColor="#2A2A2A"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>

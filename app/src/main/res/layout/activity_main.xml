<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Albo Downloader"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <!-- Connection status - tap to open settings -->
        <TextView
            android:id="@+id/connectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connecting to PC..."
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Settings panel (hidden by default) -->
        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PC SERVER URL"
                android:textColor="#555555"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/serverInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#222222"
                android:padding="10dp"
                android:inputType="textUri"
                android:hint="http://192.168.1.200:5005" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap the status text above to open/close settings"
                android:textColor="#444444"
                android:textSize="11sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- URL input box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Paste URL here..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:padding="14dp"
                android:inputType="textUri"
                android:imeOptions="actionDone"
                android:maxLines="2" />

            <Button
                android:id="@+id/pasteBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Paste"
                android:textColor="#FE2C55"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <!-- Video info card -->
        <LinearLayout
            android:id="@+id/infoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/uploaderText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste a URL to get started"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="14dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginBottom="14dp"
            android:progressTint="#FE2C55"
            android:progressBackgroundTint="#2A2A2A"
            android:max="100"
            android:visibility="gone" />

        <!-- Format menu - matches Telegram bot buttons -->
        <LinearLayout
            android:id="@+id/menuPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Video button -->
            <Button
                android:id="@+id/btnVideo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="🎬  Video (Best Quality)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E" />

            <!-- Audio button -->
            <Button
                android:id="@+id/btnAudio"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="🎵  Audio (MP3)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E" />

            <!-- Playlist button - only shown for playlist URLs -->
            <Button
                android:id="@+id/btnPlaylist"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:text="📋  Download Playlist (up to 150)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="#1E1E1E"
                android:visibility="gone" />

            <!-- Subtitles toggle -->
            <CheckBox
                android:id="@+id/subtitlesCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Include subtitles (SRT)"
                android:textColor="#888888"
                android:textSize="13sp"
                android:buttonTint="#FE2C55"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Supported sites footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TikTok  •  YouTube  •  Instagram  •  Twitter/X  •  Facebook  •  Reddit  •  Vimeo  •  Twitch  •  and more"
            android:textColor="#2A2A2A"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
